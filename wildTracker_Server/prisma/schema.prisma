generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
 REPORTER_SELLER
  MEMBER 
}
enum AuthProvider {
  EMAIL
}


model User {
  id        String   @id @default(cuid())
  email     String   @unique
  fullName      String?
  password   String
  role      Role     @default(MEMBER)
  provider  AuthProvider @default(EMAIL)
  city      String?
  state     String?
  country   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

